# Apache rewrite engine configuration
# Routes all requests through public/index.php

<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Set the RewriteBase to match the installation directory
    # If installing at root: RewriteBase /
    # If installing in subdirectory: RewriteBase /subdirectory/
    RewriteBase /
    
    # Don't rewrite if the file/directory exists
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    
    # Route all requests to public/index.php
    RewriteRule ^(.*)$ public/index.php [L]
</IfModule>

# Basic security headers
<IfModule mod_headers.c>
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-Content-Type-Options "nosniff"
    Header set X-XSS-Protection "1; mode=block"
</IfModule>
