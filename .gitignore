# Git Ignore File

# Environment
.env
.env.local
.env.*.local

# Logs
storage/logs/*
!storage/logs/.gitkeep

# IDE
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# OS
.DS_Store
Thumbs.db

# PHP
*.phtml
php_errors.log
.phpunit.result.cache

# Dependencies
vendor/
node_modules/

# Temporary
tmp/
temp/
*.tmp
*.cache

# Build
dist/
build/

# Session
session/
sessions/

# Composer
composer.lock
